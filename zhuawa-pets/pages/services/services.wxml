<view style="padding:20rpx;">
  <!-- 调试信息 -->
  <view style="background:#ffeb3b;padding:20rpx;margin-bottom:20rpx;border-radius:12rpx;">
    <text style="font-size:28rpx;color:#333;font-weight:bold;display:block;">状态: {{debugInfo}}</text>
    <text wx:if="{{errorDetail}}" style="font-size:22rpx;color:#666;display:block;margin-top:10rpx;word-break:break-all;">{{errorDetail}}</text>
  </view>

  <!-- 服务列表 -->
  <view wx:for="{{services}}" wx:key="_id" style="background:#fff;padding:20rpx;margin-bottom:20rpx;border-radius:12rpx;">
    <text style="font-size:32rpx;font-weight:bold;">{{item.name}}</text>
    <text style="font-size:24rpx;color:#666;display:block;margin-top:10rpx;">分类: {{item.category}}</text>
    <text style="font-size:28rpx;color:#F97316;display:block;margin-top:10rpx;">¥{{item.price}}</text>
  </view>

  <view wx:if="{{services.length===0}}" style="text-align:center;padding:60rpx;color:#999;">
    <text style="font-size:60rpx;">🛁</text>
    <text style="font-size:28rpx;display:block;margin-top:20rpx;">暂无服务数据</text>
  </view>

  <!-- 刷新按钮 -->
  <button bindtap="loadServices" style="margin-top:40rpx;background:#F97316;color:#fff;">重新加载</button>
</view>
