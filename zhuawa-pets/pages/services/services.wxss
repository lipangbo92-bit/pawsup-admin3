/* pages/services/services.wxss - 完全固定卡片尺寸 */
page {
  background-color: #F8FAFC;
  height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}

/* ========== 顶部导航栏 ========== */
.custom-nav {
  position: relative;
  height: 176rpx;
  padding-top: 88rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  width: 100%;
}

.nav-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
}

.nav-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========== 主内容区 ========== */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* ========== 左侧分类导航 ========== */
.category-nav {
  width: 200rpx;
  background-color: #FFFFFF;
  border-right: 1rpx solid #E5E7EB;
  flex-shrink: 0;
}

.category-item {
  padding: 32rpx 20rpx;
  text-align: center;
  border-left: 4rpx solid transparent;
}

.category-item.active {
  background-color: #FFF7ED;
  border-left-color: #F97316;
}

.category-text {
  font-size: 26rpx;
  color: #4B5563;
}

.category-item.active .category-text {
  color: #F97316;
  font-weight: 500;
}

/* ========== 右侧服务列表 ========== */
.service-list {
  flex: 1;
  background-color: #F8FAFC;
  overflow: hidden;
}

.service-content {
  padding: 20rpx;
}

/* ========== 服务卡片 - 完全固定尺寸 ========== */
.service-card {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  /* 完全固定的宽高 */
  width: 490rpx !important;
  height: 160rpx !important;
  box-sizing: border-box;
}

/* 图片/图标区域 - 固定120x120 */
.service-image-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.service-image {
  width: 120rpx;
  height: 120rpx;
  display: block;
}

.service-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.icon-blue { background: linear-gradient(135deg, #DBEAFE 0%, #3B82F6 100%); }
.icon-purple { background: linear-gradient(135deg, #E9D5FF 0%, #8B5CF6 100%); }
.icon-orange { background: linear-gradient(135deg, #FFEDD5 0%, #F97316 100%); }
.icon-pink { background: linear-gradient(135deg, #FCE7F3 0%, #EC4899 100%); }
.icon-indigo { background: linear-gradient(135deg, #E0E7FF 0%, #6366F1 100%); }
.icon-teal { background: linear-gradient(135deg, #CCFBF1 0%, #14B8A6 100%); }
.icon-green { background: linear-gradient(135deg, #D1FAE5 0%, #22C55E 100%); }

/* 服务信息区域 - 固定宽度 */
.service-info {
  width: 310rpx;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

/* 服务名称 - 固定78rpx高度，最多两行 */
.service-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  line-height: 1.4;
  height: 78rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 服务描述 - 固定32rpx高度，单行 */
.service-desc {
  font-size: 22rpx;
  color: #6B7280;
  line-height: 1.4;
  height: 32rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 底部价格和按钮 - 固定50rpx高度 */
.service-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 50rpx;
}

.price-wrapper {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #EF4444;
  font-weight: 500;
}

.price-value {
  font-size: 36rpx;
  color: #EF4444;
  font-weight: bold;
}

.price-unit {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-left: 4rpx;
}

.book-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.3);
}

.book-icon {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 300;
}

/* 无数据提示 */
.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}
