/* pages/index/index.wxss - 按照原型图修正 */

.home-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ========== 顶部导航栏 ========== */
.custom-nav {
  position: relative;
  height: 176rpx;
  padding-top: 88rpx;
  box-sizing: border-box;
}

.nav-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  z-index: 0;
}

.nav-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 20rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========== Banner轮播图 ========== */
.banner-section {
  margin: 24rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.banner-swiper {
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.3);
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.banner-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ========== 快速预约区 - 正方形图标 ========== */
.quick-book-section {
  margin: 32rpx 24rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: block;
}

.quick-book-list {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  gap: 40rpx;
}

.quick-book-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-book-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.quick-book-name {
  font-size: 26rpx;
  color: #1F2937;
  font-weight: 500;
}

/* ========== 金牌美容师推荐 ========== */
.technician-section {
  margin: 0 24rpx 32rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-more {
  font-size: 26rpx;
  color: #9CA3AF;
}

.technician-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.technician-card {
  display: flex;
  align-items: center;
  background-color: #F9FAFB;
  border-radius: 20rpx;
  padding: 24rpx;
}

.technician-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.technician-info {
  flex: 1;
}

.technician-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.technician-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-right: 12rpx;
}

.technician-badge {
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.technician-skill {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.technician-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.technician-rating {
  font-size: 24rpx;
  color: #F59E0B;
  font-weight: 500;
}

.technician-orders {
  font-size: 24rpx;
  color: #9CA3AF;
}

.technician-book-btn {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.3);
}

/* ========== 热门服务 - 长方形并排 ========== */
.service-section {
  margin: 0 24rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.service-row-list {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 20rpx;
}

.service-row-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background-color: #F9FAFB;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.service-row-item:active {
  transform: scale(0.98);
  background-color: #F3F4F6;
}

.service-row-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.service-row-name {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
}
