/* pages/index/index.wxss - 修正版 */

.home-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ========== 顶部导航栏 ========== */
.custom-nav {
  position: relative;
  height: 176rpx;
  padding-top: 88rpx;
  box-sizing: border-box;
}

.nav-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  z-index: 0;
}

.nav-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 20rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========== Banner轮播图 - 下移避免重叠 ========== */
.banner-section {
  margin: 24rpx;
  margin-top: 20rpx;  /* 从负值改为正值，避免与顶部重叠 */
  position: relative;
  z-index: 2;
}

.banner-swiper {
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.3);
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.banner-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ========== 快速预约区 ========== */
.quick-book-section {
  margin: 32rpx 24rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: block;
}

.quick-book-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 20rpx;
}

.quick-book-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background-color: #F9FAFB;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.quick-book-card:active {
  transform: scale(0.98);
  background-color: #F3F4F6;
}

.quick-book-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.quick-book-name {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
}

/* ========== 金牌美容师推荐 - 岗位在名字和等级之间 ========== */
.technician-section {
  margin: 0 24rpx 32rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-more {
  font-size: 26rpx;
  color: #9CA3AF;
}

.technician-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.technician-card {
  display: flex;
  align-items: center;
  background-color: #F9FAFB;
  border-radius: 20rpx;
  padding: 24rpx;
}

.technician-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.technician-info {
  flex: 1;
}

/* 第一排：名字 + 岗位 + 等级 */
.technician-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.technician-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.technician-position {
  font-size: 24rpx;
  color: #6B7280;
  background-color: #E5E7EB;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.technician-badge {
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 第二排：评分和订单数 */
.technician-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.technician-rating {
  font-size: 24rpx;
  color: #F59E0B;
  font-weight: 500;
}

.technician-orders {
  font-size: 24rpx;
  color: #9CA3AF;
}

.technician-book-btn {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

/* ========== 热门服务 ========== */
.hot-service-section {
  margin: 0 24rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.hot-service-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.hot-service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: #F9FAFB;
  border-radius: 16rpx;
}

.hot-service-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FED7AA 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.hot-service-name {
  font-size: 24rpx;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.hot-service-price {
  font-size: 22rpx;
  color: #F97316;
  font-weight: 600;
}
/* pages/index/index.wxss - 添加弹窗样式 */

/* ========== 弹窗遮罩 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
}

/* ========== 弹窗内容 ========== */
.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.modal-close {
  font-size: 48rpx;
  color: #9CA3AF;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  padding: 40rpx 30rpx;
}

/* 弹窗头像 */
.modal-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 弹窗基本信息 */
.modal-info {
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 16rpx;
}

.modal-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.modal-tag {
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.modal-tag.tag-level {
  color: #F97316;
  background: #FFF7ED;
}

.modal-stats {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.modal-stat {
  font-size: 26rpx;
  color: #4B5563;
}

/* 弹窗简介 */
.modal-desc {
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.desc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 12rpx;
}

.desc-content {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  display: block;
}

/* 弹窗预约按钮 */
.modal-book-btn {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
}
