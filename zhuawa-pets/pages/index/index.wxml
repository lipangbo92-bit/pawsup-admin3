<!--首页 - 带调试-->
<view class="home-container">
  <!-- 调试信息 -->
  <view style="background:#fff3cd;padding:10px;margin:10px;border-radius:8px;" bindtap="loadData">
    <text style="color:#856404;font-size:12px;">点击重新加载 | {{debugInfo}}</text>
  </view>

  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-bg"></view>
    <view class="nav-content">
      <view class="nav-placeholder"></view>
      <text class="nav-title">PawsUp爪哇宠屋</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- Banner轮播图 -->
  <view class="banner-section">
    <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="3000">
      <swiper-item class="banner-item" style="background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);">
        <text class="banner-title">专业宠物美容</text>
        <text class="banner-subtitle">让您的爱宠焕然一新</text>
      </swiper-item>
    </swiper>
  </view>

  <!-- 金牌技师推荐 -->
  <view class="technician-section">
    <view class="section-header">
      <text class="section-title">金牌技师推荐 ({{technicians.length}}人)</text>
      <text class="section-more">更多 ›</text>
    </view>
    <view class="technician-list">
      <view wx:for="{{technicians}}" wx:key="id" class="technician-card">
        <view class="technician-avatar">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill" style="width:100%;height:100%;border-radius:50%;"/>
          <text wx:else style="font-size:48rpx;">👤</text>
        </view>
        <view class="technician-info">
          <view class="technician-name-row">
            <text class="technician-name">{{item.name}}</text>
            <text class="technician-badge">{{item.level}}</text>
          </view>
          <text class="technician-skill">{{item.position}}</text>
          <view class="technician-stats">
            <text class="technician-rating">⭐ {{item.rating}}分</text>
            <text class="technician-orders">{{item.orders}}单</text>
          </view>
        </view>
        <view class="technician-book-btn">预约</view>
      </view>
      <view wx:if="{{technicians.length === 0}}" style="text-align:center;padding:40rpx;color:#999;">
        暂无技师数据，点击上方黄色区域重新加载
      </view>
    </view>
  </view>
</view>
