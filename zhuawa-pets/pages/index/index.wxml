<!--首页-->
<view class="home-container">
  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-bg"></view>
    <view class="nav-content">
      <view class="nav-placeholder"></view>
      <text class="nav-title">PawsUp爪哇宠屋</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- Banner轮播图 -->
  <view class="banner-section">
    <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="3000">
      <swiper-item class="banner-item" style="background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);">
        <text class="banner-title">专业宠物美容</text>
        <text class="banner-subtitle">让您的爱宠焕然一新</text>
      </swiper-item>
    </swiper>
  </view>

  <!-- 快速预约区 -->
  <view class="quick-book-section">
    <text class="section-title">快速预约</text>
    <view class="quick-book-list">
      <view class="quick-book-card quick-book-card-1" bindtap="goToServices">
        <view class="quick-book-icon">✂️</view>
        <view class="quick-book-info">
          <text class="quick-book-name">预约美容</text>
        </view>
      </view>
      <view class="quick-book-card quick-book-card-2">
        <view class="quick-book-icon">🛁</view>
        <view class="quick-book-info">
          <text class="quick-book-name">预约洗澡</text>
        </view>
      </view>
      <view class="quick-book-card quick-book-card-3">
        <view class="quick-book-icon">🏥</view>
        <view class="quick-book-info">
          <text class="quick-book-name">宠物医疗</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 金牌美容师推荐 -->
  <view class="technician-section">
    <view class="section-header">
      <text class="section-title">金牌美容师推荐</text>
      <text class="section-more">更多 ›</text>
    </view>
    
    <!-- 美容师列表 -->
    <view class="technician-list" wx:if="{{technicians && technicians.length > 0}}">
      <view wx:for="{{technicians}}" wx:key="index" class="technician-card">
        <view class="technician-avatar">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill" style="width:100%;height:100%;border-radius:50%;"/>
          <text wx:else style="font-size:48rpx;">👤</text>
        </view>
        <view class="technician-info">
          <view class="technician-name-row">
            <text class="technician-name">{{item.name}}</text>
            <text class="technician-badge">{{item.level}}</text>
          </view>
          <text class="technician-skill">{{item.position}}</text>
          <view class="technician-stats">
            <text class="technician-rating">⭐ {{item.rating}}分</text>
            <text class="technician-orders">{{item.orders}}单</text>
          </view>
        </view>
        <view class="technician-book-btn">预约</view>
      </view>
    </view>
    
    <!-- 无数据提示 -->
    <view wx:else style="text-align:center;padding:40rpx;color:#999;">
      暂无美容师数据
    </view>
  </view>

  <!-- 热门服务 -->
  <view class="service-section">
    <view class="section-header">
      <text class="section-title">热门服务</text>
      <text class="section-more" bindtap="goToServices">更多 ›</text>
    </view>
    <view class="service-grid">
      <view wx:for="{{services}}" wx:key="index" class="service-card" bindtap="goToBooking" data-id="{{item.id}}">
        <view class="service-icon-wrapper">
          <text class="service-icon">🐾</text>
        </view>
        <text class="service-name">{{item.name}}</text>
        <text class="service-price">¥{{item.price}}起</text>
      </view>
    </view>
  </view>
</view>
