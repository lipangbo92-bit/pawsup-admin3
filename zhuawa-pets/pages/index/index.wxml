<!--首页 - 详细调试-->
<view class="home-container">
  <!-- 调试信息 -->
  <view style="background:#ffeb3b;padding:10px;margin:10px;border-radius:8px;" bindtap="reload">
    <text style="color:#333;font-size:12px;font-weight:bold;">{{debugMsg}}</text>
    <text style="color:#666;font-size:10px;display:block;">点击重新加载</text>
  </view>

  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-bg"></view>
    <view class="nav-content">
      <view class="nav-placeholder"></view>
      <text class="nav-title">PawsUp爪哇宠屋</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 金牌美容师推荐 -->
  <view class="technician-section">
    <view class="section-header">
      <text class="section-title">金牌美容师推荐</text>
    </view>
    
    <view class="technician-list" wx:if="{{technicians.length > 0}}">
      <view wx:for="{{technicians}}" wx:key="index" class="technician-card">
        <view class="technician-avatar">
          <image wx:if="{{item.avatarUrl || item.avatar}}" src="{{item.avatarUrl || item.avatar}}" mode="aspectFill" style="width:100%;height:100%;border-radius:50%;"/>
          <text wx:else style="font-size:48rpx;">👤</text>
        </view>
        <view class="technician-info">
          <text class="technician-name">{{item.name}}</text>
          <text style="font-size:12px;color:#666;">{{item.level}}{{item.position}}</text>
        </view>
      </view>
    </view>
    
    <view wx:else style="text-align:center;padding:40rpx;color:#999;">
      暂无美容师数据 ({{technicians.length}})
    </view>
  </view>
</view>
