<!--首页 - 修复版-->
<view class="home-container">
  <!-- 调试信息 -->
  <view style="background:#ffeb3b;padding:10px;margin:10px;border-radius:8px;" bindtap="reload">
    <text style="color:#333;font-size:12px;font-weight:bold;">{{debugMsg}}</text>
  </view>

  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-bg"></view>
    <view class="nav-content">
      <text class="nav-title">PawsUp爪哇宠屋</text>
    </view>
  </view>

  <!-- 金牌美容师推荐 -->
  <view style="margin:20rpx;background:#fff;border-radius:16rpx;padding:20rpx;">
    <text style="font-size:32rpx;font-weight:bold;margin-bottom:20rpx;display:block;">金牌美容师推荐</text>
    
    <!-- 美容师列表 -->
    <view wx:if="{{technicians.length > 0}}">
      <view wx:for="{{technicians}}" wx:key="*this" style="display:flex;align-items:center;padding:20rpx;border-bottom:1rpx solid #eee;">
        <view style="width:100rpx;height:100rpx;background:#f0f0f0;border-radius:50%;display:flex;align-items:center;justify-content:center;overflow:hidden;">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" style="width:100%;height:100%;"/>
          <text wx:else style="font-size:60rpx;">👤</text>
        </view>
        <view style="margin-left:20rpx;flex:1;">
          <text style="font-size:30rpx;font-weight:500;display:block;">{{item.name}}</text>
          <text style="font-size:24rpx;color:#666;">{{item.level}}{{item.position}} ⭐{{item.rating}}分 {{item.orders}}单</text>
        </view>
      </view>
    </view>
    
    <view wx:else style="text-align:center;padding:40rpx;color:#999;">
      暂无美容师数据
    </view>
  </view>
</view>
