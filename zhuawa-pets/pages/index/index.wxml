<!--首页 - 安全版-->
<view class="container" style="min-height:100vh;background:#f5f5f5;">
  <!--Banner-->
  <view style="background:#F97316;padding:40px 20px;text-align:center;">
    <text style="color:white;font-size:20px;font-weight:bold;">PawsUp爪哇宠屋</text>
  </view>

  <!--快捷入口-->
  <view style="display:flex;justify-content:space-around;padding:20px;background:white;margin:10px;border-radius:8px;">
    <view bindtap="goToServices" style="text-align:center;">
      <text style="font-size:30px;">✂️</text>
      <text style="display:block;font-size:14px;">预约美容</text>
    </view>
    <view style="text-align:center;">
      <text style="font-size:30px;">🛁</text>
      <text style="display:block;font-size:14px;">预约洗澡</text>
    </view>
    <view style="text-align:center;">
      <text style="font-size:30px;">🏥</text>
      <text style="display:block;font-size:14px;">宠物医疗</text>
    </view>
  </view>

  <!--热门服务-->
  <view style="background:white;margin:10px;padding:15px;border-radius:8px;">
    <view style="display:flex;justify-content:space-between;margin-bottom:15px;">
      <text style="font-weight:bold;">热门服务</text>
      <text bindtap="goToServices" style="color:#F97316;">更多 ›</text>
    </view>
    <view style="display:flex;flex-wrap:wrap;gap:10px;">
      <view wx:for="{{services}}" wx:key="id" bindtap="goToBooking" data-id="{{item.id}}" style="width:30%;text-align:center;">
        <view style="background:#f0f0f0;height:80px;border-radius:8px;margin-bottom:8px;"></view>
        <text style="font-size:14px;">{{item.name}}</text>
        <text style="display:block;color:#F97316;font-size:12px;">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <!--推荐技师-->
  <view style="background:white;margin:10px;padding:15px;border-radius:8px;">
    <text style="font-weight:bold;display:block;margin-bottom:15px;">推荐技师</text>
    <view style="display:flex;flex-wrap:wrap;gap:10px;">
      <view wx:for="{{technicians}}" wx:key="id" style="width:30%;text-align:center;padding:10px;background:#f9f9f9;border-radius:8px;">
        <view style="width:60px;height:60px;border-radius:50%;background:#e0e0e0;margin:0 auto;overflow:hidden;">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" style="width:100%;height:100%;border-radius:50%;"/>
          <text wx:else style="font-size:30px;line-height:60px;">👤</text>
        </view>
        <text style="display:block;margin-top:8px;font-size:14px;font-weight:500;">{{item.name}}</text>
        <text style="font-size:12px;color:#666;">{{item.displayTitle}}</text>
      </view>
    </view>
    <text wx:if="{{technicians.length === 0}}" style="display:block;text-align:center;color:#999;padding:20px;">暂无技师数据</text>
  </view>
</view>
