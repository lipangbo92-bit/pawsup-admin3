<!--首页 - 显示API返回-->
<view style="padding:10px;background:#f5f5f5;min-height:100vh;">
  <!-- 调试信息 -->
  <view style="background:#ffeb3b;padding:10px;margin-bottom:10px;border-radius:8px;">
    <text style="color:#333;font-size:12px;font-weight:bold;">{{debugMsg}}</text>
  </view>
  
  <!-- API返回内容 -->
  <view style="background:#fff;padding:10px;margin-bottom:10px;border-radius:8px;">
    <text style="font-size:12px;color:#666;display:block;margin-bottom:5px;">API返回:</text>
    <text style="font-size:10px;color:#333;white-space:pre-wrap;word-break:break-all;">{{apiResult || '无'}}</text>
  </view>

  <!-- 美容师列表 -->
  <view style="background:#fff;padding:15px;border-radius:8px;">
    <text style="font-size:16px;font-weight:bold;margin-bottom:10px;display:block;">金牌美容师推荐</text>
    
    <view wx:if="{{technicians.length > 0}}">
      <view wx:for="{{technicians}}" wx:key="index" style="display:flex;align-items:center;padding:10px;border-bottom:1px solid #eee;">
        <view style="width:50px;height:50px;background:#f0f0f0;border-radius:50%;display:flex;align-items:center;justify-content:center;">
          <text wx:if="{{!item.avatar}}" style="font-size:30px;">👤</text>
          <image wx:else src="{{item.avatar}}" style="width:100%;height:100%;border-radius:50%;"/>
        </view>
        <view style="margin-left:10px;">
          <text style="font-size:14px;font-weight:bold;display:block;">{{item.name}}</text>
          <text style="font-size:12px;color:#666;">{{item.level}}{{item.position}} ⭐{{item.rating}}分</text>
        </view>
      </view>
    </view>
    
    <view wx:else style="text-align:center;padding:20px;color:#999;">
      暂无美容师数据
    </view>
  </view>
</view>
