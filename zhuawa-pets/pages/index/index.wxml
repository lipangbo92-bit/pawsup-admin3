<!--首页 - 从数据库加载Banner-->
<view class="home-container">
  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-bg"></view>
    <view class="nav-content">
      <text class="nav-title">PawsUp爪哇宠屋</text>
    </view>
  </view>

  <!-- Banner轮播图 - 从数据库加载 -->
  <view class="banner-section">
    <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="3000" wx:if="{{banners.length > 0}}">
      <swiper-item wx:for="{{banners}}" wx:key="_id" class="banner-item" style="background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" class="banner-bg-image"/>
        <view class="banner-text-wrapper">
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-subtitle">{{item.subtitle}}</text>
        </view>
      </swiper-item>
    </swiper>
    <!-- 默认Banner（无数据时显示） -->
    <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="3000" wx:if="{{banners.length === 0}}">
      <swiper-item class="banner-item" style="background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);">
        <text class="banner-title">专业宠物美容</text>
        <text class="banner-subtitle">让您的爱宠焕然一新</text>
      </swiper-item>
    </swiper>
  </view>

  <!-- 快速预约区 -->
  <view class="quick-book-section">
    <text class="section-title">快速预约</text>
    <view class="quick-book-row">
      <view class="quick-book-card" bindtap="goToService" data-service="洗护美容">
        <view class="quick-book-icon" style="background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);">🛁</view>
        <text class="quick-book-name">洗护美容</text>
      </view>
      <view class="quick-book-card" bindtap="goToService" data-service="寄养日托">
        <view class="quick-book-icon" style="background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);">🏠</view>
        <text class="quick-book-name">寄养日托</text>
      </view>
      <view class="quick-book-card" bindtap="goToService" data-service="上门服务">
        <view class="quick-book-icon" style="background: linear-gradient(135deg, #10B981 0%, #059669 100%);">🚗</view>
        <text class="quick-book-name">上门服务</text>
      </view>
    </view>
  </view>

  <!-- 金牌美容师推荐 -->
  <view class="technician-section">
    <view class="section-header">
      <text class="section-title">金牌美容师推荐</text>
      <text class="section-more">更多 ›</text>
    </view>
    
    <view class="technician-list">
      <view wx:for="{{technicians}}" wx:key="index" class="technician-card" bindtap="showTechnicianDetail" data-index="{{index}}">
        <!-- 头像 -->
        <view class="technician-avatar" catchtap="preventBubble">
          <block wx:if="{{item.avatar && item.avatar.length > 10}}">
            <image src="{{item.avatar}}" mode="aspectFill" style="width:100%;height:100%;border-radius:50%;"/>
          </block>
          <block wx:else>
            <text style="font-size:48rpx;">👤</text>
          </block>
        </view>
        
        <view class="technician-info" catchtap="preventBubble">
          <view class="technician-name-row">
            <text class="technician-name">{{item.name}}</text>
            <text class="technician-position">{{item.position}}</text>
            <text class="technician-badge">{{item.level}}</text>
          </view>
          <view class="technician-stats">
            <text class="technician-rating">⭐ {{item.rating}}分</text>
            <text class="technician-orders">{{item.orders}}单</text>
          </view>
        </view>
        <view class="technician-book-btn" catchtap="bookTechnician" data-index="{{index}}">预约</view>
      </view>
    </view>
  </view>

  <!-- 热门服务 -->
  <view class="hot-service-section">
    <view class="section-header">
      <text class="section-title">热门服务</text>
      <text class="section-more" bindtap="goToServices">更多 ›</text>
    </view>
    <view class="hot-service-list">
      <view wx:for="{{services}}" wx:key="index" class="hot-service-item" bindtap="goToBooking" data-id="{{item.id}}">
        <view class="hot-service-icon">🐾</view>
        <text class="hot-service-name">{{item.name}}</text>
        <text class="hot-service-price">¥{{item.price}}起</text>
      </view>
    </view>
  </view>

  <!-- 美容师详情弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="modal-content" wx:if="{{showModal}}">
    <view class="modal-header">
      <text class="modal-title">美容师介绍</text>
      <text class="modal-close" bindtap="closeModal">×</text>
    </view>
    <view class="modal-body" wx:if="{{selectedTechnician}}">
      <view class="modal-avatar">
        <block wx:if="{{selectedTechnician.avatar && selectedTechnician.avatar.length > 10}}">
          <image src="{{selectedTechnician.avatar}}" mode="aspectFill" style="width:100%;height:100%;border-radius:50%;"/>
        </block>
        <block wx:else>
          <text style="font-size:80rpx;">👤</text>
        </block>
      </view>
      <view class="modal-info">
        <text class="modal-name">{{selectedTechnician.name}}</text>
        <view class="modal-tags">
          <text class="modal-tag">{{selectedTechnician.position}}</text>
          <text class="modal-tag tag-level">{{selectedTechnician.level}}</text>
        </view>
        <view class="modal-stats">
          <text class="modal-stat">⭐ {{selectedTechnician.rating}}分</text>
          <text class="modal-stat">📋 {{selectedTechnician.orders}}单</text>
        </view>
      </view>
      <view class="modal-desc">
        <text class="desc-title">个人简介</text>
        <text class="desc-content">{{selectedTechnician.intro}}</text>
      </view>
      <view class="modal-book-btn" bindtap="bookFromModal">立即预约</view>
    </view>
  </view>
</view>
