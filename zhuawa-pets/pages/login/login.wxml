<!--pages/login/login.wxml-->
<view class="login-container">
  <!-- 品牌区域 -->
  <view class="login-header">
    <view class="brand-logo">
      <text class="brand-icon">🐾</text>
    </view>
    <view class="brand-title">爪哇宠屋</view>
    <view class="brand-subtitle">专业宠物护理服务</view>
  </view>

  <!-- 已登录状态 -->
  <block wx:if="{{hasUserInfo}}">
    <view class="user-card">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-name">{{userInfo.nickName}}</view>
      <view class="user-phone" wx:if="{{userInfo.phoneNumber}}">{{userInfo.phoneNumber}}</view>
    </view>

    <view class="login-options">
      <view class="status-tag">已登录</view>
      <button class="btn btn-primary" bindtap="goToHome">
        进入首页
      </button>
      <button class="btn btn-outline" bindtap="logout">
        切换账号
      </button>
    </view>
  </block>

  <!-- 未登录状态 -->
  <block wx:else>
    <view class="login-options">
      <view class="option-title">欢迎使用</view>
      <view class="option-desc">登录后即可预约专业宠物服务</view>

      <!-- 微信授权登录 -->
      <button wx:if="{{canIUseGetUserProfile}}" class="btn btn-primary" bindtap="getUserProfile">
        <text class="btn-icon">💬</text>
        <text>微信一键登录</text>
      </button>

      <button wx:else class="btn btn-primary" open-type="getUserInfo" bindgetuserinfo="getUserInfo">
        <text class="btn-icon">💬</text>
        <text>微信一键登录</text>
      </button>

      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">或</text>
        <view class="divider-line"></view>
      </view>

      <!-- 测试账号 -->
      <button class="btn btn-secondary" bindtap="skipLogin">
        使用测试账号体验
      </button>
    </view>
  </block>

  <!-- 底部协议 -->
  <view class="login-footer">
    <text class="agreement-text">
      登录即代表您同意
      <text class="agreement-link">《用户协议》</text>
      和
      <text class="agreement-link">《隐私政策》</text>
    </text>
  </view>
</view>
