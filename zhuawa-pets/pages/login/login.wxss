/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  padding: 0 60rpx;
  box-sizing: border-box;
}

/* 顶部区域 */
.login-header {
  padding-top: 120rpx;
  padding-bottom: 80rpx;
  text-align: center;
}

.brand-logo {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.25);
}

.brand-icon {
  font-size: 64rpx;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
  letter-spacing: -0.5rpx;
}

.brand-subtitle {
  font-size: 28rpx;
  color: #6b7280;
}

/* 用户信息卡片 */
.user-card {
  background: #f9fafb;
  border-radius: 20rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 28rpx;
  color: #6b7280;
}

/* 登录选项 */
.login-options {
  flex: 1;
}

.option-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
  text-align: center;
}

.option-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 48rpx;
  text-align: center;
  line-height: 1.6;
}

/* 按钮样式 */
.btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #F97316;
  color: #ffffff;
}

.btn-primary:active {
  background: #EA580C;
}

.btn-secondary {
  background: #f3f4f6;
  color: #4b5563;
}

.btn-secondary:active {
  background: #e5e7eb;
}

.btn-outline {
  background: #ffffff;
  color: #6b7280;
  border: 2rpx solid #e5e7eb;
}

.btn-outline:active {
  background: #f9fafb;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #e5e7eb;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

/* 底部区域 */
.login-footer {
  padding: 40rpx 0 60rpx;
  text-align: center;
}

.agreement-text {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.5;
}

.agreement-link {
  color: #F97316;
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #dcfce7;
  color: #16a34a;
  font-size: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}

.status-tag::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  background: #16a34a;
  border-radius: 50%;
  margin-right: 10rpx;
}
