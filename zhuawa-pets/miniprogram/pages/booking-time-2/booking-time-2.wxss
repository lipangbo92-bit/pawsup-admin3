.container {
  min-height: 100vh;
  background: var(--bg, #FDF2F8);
  padding: 16px;
  padding-bottom: 100px;
}

.date-display {
  font-size: 20px;
  font-weight: 600;
  color: var(--text, #1F2937);
  text-align: center;
  margin-bottom: 20px;
}

.section {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 20px rgba(236, 72, 153, 0.1);
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text, #1F2937);
  margin-bottom: 12px;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.time-item {
  padding: 12px 8px;
  text-align: center;
  border-radius: 8px;
  background: var(--bg, #FDF2F8);
  font-size: 14px;
  color: var(--text, #1F2937);
}

.time-item.selected {
  background: var(--primary, #EC4899);
  color: #fff;
}

.time-item.disabled {
  background: #f0f0f0;
  color: #ccc;
}

.tech-list {
  display: flex;
  gap: 12px;
  overflow-x: auto;
}

.tech-item {
  flex-shrink: 0;
  width: 80px;
  padding: 12px;
  text-align: center;
  border-radius: 12px;
  background: var(--bg, #FDF2F8);
}

.tech-item.selected {
  background: #FCE7F3;
  border: 2px solid var(--primary, #EC4899);
}

.tech-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #ddd;
  margin: 0 auto 8px;
}

.tech-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--text, #1F2937);
  display: block;
}

.tech-level {
  font-size: 11px;
  color: var(--text-secondary, #6B7280);
  margin-top: 2px;
  display: block;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16px;
}

.confirm-btn {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  color: #fff;
  border: none;
  height: 48px;
  line-height: 48px;
  border-radius: 24px;
  font-size: 16px;
}

.confirm-btn[disabled] {
  background: #ccc;
}
