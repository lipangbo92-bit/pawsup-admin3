<!--首页 - 调试版-->
<view class="container">
  <!--Banner-->
  <view class="banner">
    <view class="banner-placeholder">爪哇宠物店</view>
  </view>

  <!--快捷入口-->
  <view class="quick-entry">
    <view class="entry-item" bindtap="goToServices">
      <text class="entry-icon">✂️</text>
      <text class="entry-text">预约美容</text>
    </view>
    <view class="entry-item">
      <text class="entry-icon">🛁</text>
      <text class="entry-text">预约洗澡</text>
    </view>
  </view>

  <!--推荐技师-->
  <view class="section">
    <view class="section-header">
      <text class="section-title">推荐技师</text>
    </view>
    <view class="tech-list">
      <view wx:for="{{technicians}}" wx:key="id" class="tech-card">
        <view class="tech-avatar" style="background:#f0f0f0;display:flex;align-items:center;justify-content:center;width:60px;height:60px;border-radius:50%;overflow:hidden;">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill" style="width:100%;height:100%;"/>
          <text wx:else style="font-size:24px;">👤</text>
        </view>
        <text style="margin-top:8px;font-size:14px;">{{item.name}}</text>
        <text style="font-size:12px;color:#666;">{{item.displayTitle}}</text>
        <!-- 显示原始数据 -->
        <text style="font-size:10px;color:red;margin-top:4px;word-break:break-all;padding:0 10px;text-align:center;">{{item.avatar || '无头像URL'}}</text>
      </view>
    </view>
  </view>
</view>
