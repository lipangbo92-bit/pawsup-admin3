.container {
  min-height: 100vh;
  background: var(--bg, #FDF2F8);
}

.status-tabs {
  display: flex;
  background: #fff;
  padding: 12px 16px;
  gap: 8px;
  overflow-x: auto;
}

.tab-item {
  padding: 8px 16px;
  font-size: 14px;
  color: var(--text-secondary, #6B7280);
  border-radius: 20px;
  white-space: nowrap;
}

.tab-item.active {
  background: var(--primary, #EC4899);
  color: #fff;
}

.order-list {
  padding: 16px;
}

.order-card {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 4px 20px rgba(236, 72, 153, 0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border, #E5E7EB);
}

.order-no {
  font-size: 12px;
  color: var(--text-secondary, #6B7280);
}

.order-status {
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 12px;
}

.status-pending {
  background: #FEF3C7;
  color: #D97706;
}

.status-paid {
  background: #DBEAFE;
  color: #2563EB;
}

.status-completed {
  background: #D1FAE5;
  color: #059669;
}

.status-canceled {
  background: #F3F4F6;
  color: #6B7280;
}

.order-body {
  margin-bottom: 12px;
}

.service-name {
  font-size: 16px;
  font-weight: 600;
  color: var(--text, #1F2937);
  margin-bottom: 8px;
}

.order-info {
  display: flex;
  gap: 16px;
  font-size: 13px;
  color: var(--text-secondary, #6B7280);
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 18px;
  font-weight: 600;
  color: var(--primary, #EC4899);
}

.arrow {
  font-size: 20px;
  color: var(--text-secondary, #6B7280);
}

.empty, .loading {
  text-align: center;
  padding: 40px;
  color: var(--text-secondary, #6B7280);
  font-size: 14px;
}
