/* pages/booking-confirm/booking-confirm.wxss */
page {
  background: #FDF2F8;
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.header {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back, .title, .placeholder {
  color: #fff;
  font-size: 34rpx;
}

.back {
  font-size: 40rpx;
}

/* Card */
.card {
  background: #fff;
  margin: 32rpx;
  border-radius: 24rpx;
  padding: 32rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-row .label {
  color: #6B7280;
  font-size: 28rpx;
}

.info-row .value {
  color: #1F2937;
  font-size: 28rpx;
}

.info-row .value.highlight {
  color: #EC4899;
  font-weight: 600;
}

/* Remark */
.remark-input {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1F2937;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price .label {
  color: #6B7280;
  font-size: 26rpx;
}

.price .amount {
  color: #EC4899;
  font-size: 40rpx;
  font-weight: 700;
}

.submit-btn {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  color: #fff;
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
}
