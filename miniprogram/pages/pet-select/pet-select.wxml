<!--pages/pet-select/pet-select.wxml-->
<view class="container">
  <view class="header">
    <view class="back" bindtap="goBack">←</view>
    <view class="title">选择宠物</view>
    <view class="placeholder"></view>
  </view>
  
  <!-- 预约信息 -->
  <view class="info-bar">
    <text>{{date}} {{time}}</text>
  </view>
  
  <!-- 宠物列表 -->
  <view class="section">
    <view class="section-title">我的宠物</view>
    
    <view class="pet-list">
      <view 
        class="pet-card {{selectedPet._id === item._id ? 'selected' : ''}}"
        wx:for="{{pets}}"
        wx:key="_id"
      >
        <!-- 左侧：点击选择宠物 -->
        <view class="pet-main" bindtap="onSelectPet" data-id="{{item._id}}">
          <image 
            wx:if="{{item.avatar && !item.avatarError}}" 
            class="pet-avatar-img" 
            src="{{item.avatar}}" 
            mode="aspectFill"
            binderror="onAvatarError"
            data-index="{{index}}"
          />
          <view wx:else class="pet-avatar">{{item.type === 'dog' ? '🐕' : item.type === 'cat' ? '🐈' : '🐾'}}</view>
          <view class="pet-info">
            <view class="pet-name">{{item.name}}</view>
            <view class="pet-meta">{{item.breed}} · {{item.age}}岁</view>
          </view>
        </view>
        
        <!-- 右侧：操作按钮 -->
        <view class="pet-actions">
          <view class="action-btn edit" catchtap="onEditPet" data-id="{{item._id}}">编辑</view>
          <view class="action-btn delete" catchtap="onDeletePet" data-id="{{item._id}}">删除</view>
          <view class="pet-check" wx:if="{{selectedPet._id === item._id}}">✓</view>
        </view>
      </view>
      
      <!-- 添加新宠物 -->
      <view class="pet-card add-pet" bindtap="goToAddPet">
        <view class="pet-avatar">➕</view>
        <view class="pet-info">
          <view class="pet-name">添加宠物</view>
          <view class="pet-meta">添加新宠物信息</view>
        </view>
      </view>
    </view>
    
    <view class="empty-tip" wx:if="{{pets.length === 0}}">
      <view class="empty-icon">🐾</view>
      <view class="empty-text">还没有添加宠物</view>
      <view class="empty-btn" bindtap="goToAddPet">添加宠物</view>
    </view>
  </view>
  
  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="selected-info" wx:if="{{selectedPet}}">
      {{selectedPet.name}}
    </view>
    <view class="next-btn {{selectedPet ? 'active' : ''}}" bindtap="goToConfirm">
      下一步
    </view>
  </view>
</view>
