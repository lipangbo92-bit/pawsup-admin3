/* pages/pet-select/pet-select.wxss */
page {
  background: #FDF2F8;
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.header {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back, .title, .placeholder {
  color: #fff;
  font-size: 34rpx;
}

.back {
  font-size: 40rpx;
}

.info-bar {
  background: #fff;
  margin: 32rpx;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  text-align: center;
  color: #EC4899;
  font-size: 28rpx;
  font-weight: 500;
}

.section {
  padding: 0 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.pet-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pet-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(236, 72, 153, 0.08);
}

.pet-card.selected {
  border: 2rpx solid #EC4899;
  background: #FDF2F8;
}

.pet-card.add-pet {
  border: 2rpx dashed #D1D5DB;
  background: #fff;
}

/* 左侧主要内容区 */
.pet-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

/* 右侧操作按钮区 */
.pet-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.edit {
  background: #F3F4F6;
  color: #6B7280;
}

.action-btn.delete {
  background: #FEE2E2;
  color: #EF4444;
}

.action-btn:active {
  opacity: 0.7;
}

.pet-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FBCFE8 0%, #F9A8D4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.pet-avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid #F9A8D4;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.pet-meta {
  font-size: 24rpx;
  color: #6B7280;
}

.pet-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #EC4899;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

/* Empty */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #6B7280;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  display: inline-block;
  font-size: 28rpx;
  font-weight: 600;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.selected-info {
  color: #EC4899;
  font-size: 28rpx;
  font-weight: 500;
}

.next-btn {
  background: #D1D5DB;
  color: #fff;
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.next-btn.active {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
}
