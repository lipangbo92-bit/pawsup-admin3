<!--pages/orders/orders.wxml-->
<view class="page-container">
  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-bg"></view>
    <view class="nav-content">
      <view class="nav-placeholder"></view>
      <text class="nav-title">我的订单</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 标签切换栏 -->
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <!-- 订单卡片 -->
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="order-card"
      data-id="{{item.id}}"
      bindtap="onOrderClick"
    >
      <!-- 订单头部：编号 + 状态 -->
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <view class="status-tag status-{{item.status}} {{item.paymentStatus === 'unpaid' ? 'status-unpaid' : ''}}">
          {{item.statusText}}
        </view>
      </view>

      <!-- 订单内容 -->
      <view class="order-body">
        <view class="order-info">
          <text class="service-name">{{item.serviceName}}</text>
          <view class="meta-info">
            <text class="meta-item">{{item.date}} {{item.time}}</text>
          </view>
          <view class="pet-info" wx:if="{{item.petName}}">
            <text class="pet-label">🐾 {{item.petName}}</text>
          </view>
        </view>
      </view>

      <!-- 订单底部：价格 + 操作 -->
      <view class="order-footer">
        <view class="price-section">
          <text class="price-label">{{item.priceLabel}}：</text>
          <text class="price-value">¥{{item.displayPrice}}</text>
        </view>
        <view class="action-section">
          <!-- 待支付显示去支付按钮 -->
          <view
            class="btn btn-primary"
            wx:if="{{item.paymentStatus === 'unpaid'}}"
            catchtap="onPayOrder"
            data-id="{{item.id}}"
          >
            去支付
          </view>
          <!-- 待服务显示取消按钮 -->
          <view
            class="btn btn-default"
            wx:if="{{item.status === 'pending' && item.paymentStatus !== 'unpaid'}}"
            catchtap="onCancelOrder"
            data-id="{{item.id}}"
          >
            取消预约
          </view>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading-state">
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && orders.length === 0}}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无订单</text>
    </view>
  </view>
</view>
