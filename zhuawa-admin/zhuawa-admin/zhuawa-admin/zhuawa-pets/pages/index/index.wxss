/* pages/index/index.wxss */

.home-container {
  min-height: 100vh;
  background-color: #FFF7ED;
  padding-bottom: 40rpx;
}

/* ========== 顶部导航栏 ========== */
.custom-nav {
  position: relative;
  height: 176rpx;
  padding-top: 88rpx;
  box-sizing: border-box;
}

.nav-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  z-index: 0;
}

.nav-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 20rpx;
}

.nav-back {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 52rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.nav-placeholder {
  width: 88rpx;
}

/* 原header样式 */
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(180deg, #F97316 0%, #EA580C 100%);
}

.location-box {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.location-text {
  font-size: 26rpx;
  color: #FFFFFF;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-arrow {
  font-size: 20rpx;
  color: #FFFFFF;
  margin-left: 4rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 14rpx 24rpx;
  margin-right: 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #9CA3AF;
}

.search-placeholder {
  font-size: 26rpx;
  color: #9CA3AF;
}

.message-box {
  position: relative;
  padding: 10rpx;
}

.message-icon {
  font-size: 44rpx;
}

.message-badge {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #EF4444;
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* Banner轮播图 */
.banner-section {
  margin: 24rpx;
}

.banner-swiper {
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 快速预约区 */
.quick-book-section {
  margin: 0 24rpx 32rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 20rpx;
}

.quick-book-list {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.quick-book-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.quick-book-card:nth-child(2) {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
}

.quick-book-card:nth-child(3) {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
}

.quick-book-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.quick-book-info {
  text-align: center;
}

.quick-book-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.quick-book-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 金牌技师推荐 */
.technician-section {
  margin: 0 24rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-more {
  font-size: 26rpx;
  color: #6B7280;
}

.technician-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.technician-card {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.technician-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.technician-info {
  flex: 1;
}

.technician-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.technician-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-right: 12rpx;
}

.technician-badge {
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.technician-skill {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.technician-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.technician-rating {
  font-size: 24rpx;
  color: #F59E0B;
  font-weight: 500;
}

.technician-orders {
  font-size: 24rpx;
  color: #9CA3AF;
}

.technician-book-btn {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

/* 热门服务 */
.service-section {
  margin: 0 24rpx;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.service-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.service-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FED7AA 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.service-icon {
  font-size: 44rpx;
}

.service-name {
  font-size: 26rpx;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.service-price {
  font-size: 24rpx;
  color: #F97316;
  font-weight: 600;
}

/* 快速预约卡片颜色 */
.quick-book-card-1 {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%) !important;
}
.quick-book-card-2 {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%) !important;
}
.quick-book-card-3 {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%) !important;
}
