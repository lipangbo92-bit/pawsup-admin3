<!--订单列表页-->
<view class="container">
  <!--状态筛选-->
  <view class="status-tabs">
    <view
      wx:for="{{statusList}}"
      wx:key="key"
      class="tab-item {{status === item.key ? 'active' : ''}}"
      data-status="{{item.key}}"
      bindtap="switchStatus"
    >
      {{item.label}}
    </view>
  </view>

  <!--订单列表-->
  <view class="order-list">
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="order-card"
      data-id="{{item.id}}"
      bindtap="goToDetail"
    >
      <view class="order-header">
        <text class="order-no">{{item.orderNo || item.id}}</text>
        <text class="order-status {{item.paymentStatus === 'unpaid' ? 'status-unpaid' : ''}}">{{item.statusText}}</text>
      </view>

      <view class="order-body">
        <view class="service-name">{{item.serviceName}}</view>
        <view class="order-info">
          <text wx:if="{{item.petName}}">{{item.petName}}</text>
          <text>{{item.date}} {{item.time}}</text>
        </view>
      </view>

      <view class="order-footer">
        <view class="price-section">
          <text class="price-label">{{item.priceLabel}}：</text>
          <text class="price">¥{{item.displayPrice}}</text>
        </view>
        <view class="action-section">
          <!-- 待支付显示去支付按钮 -->
          <view
            class="btn btn-primary"
            wx:if="{{item.paymentStatus === 'unpaid'}}"
            catchtap="payOrder"
            data-id="{{item.id}}"
          >
            去支付
          </view>
          <!-- 待服务显示取消按钮 -->
          <view
            class="btn btn-default"
            wx:if="{{item.status === 'pending' && item.paymentStatus !== 'unpaid'}}"
            catchtap="cancelOrder"
            data-id="{{item.id}}"
          >
            取消预约
          </view>
          <text wx:else class="arrow">›</text>
        </view>
      </view>
    </view>

    <!--空状态-->
    <view class="empty" wx:if="{{orders.length === 0 && !loading}}">
      <text>暂无订单</text>
    </view>

    <!--加载中-->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
