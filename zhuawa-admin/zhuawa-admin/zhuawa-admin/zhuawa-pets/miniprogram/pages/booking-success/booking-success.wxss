.container {
  min-height: 100vh;
  background: var(--bg, #FDF2F8);
  padding: 40px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  color: #fff;
  margin-bottom: 24px;
}

.success-title {
  font-size: 24px;
  font-weight: 600;
  color: var(--text, #1F2937);
  margin-bottom: 8px;
}

.success-desc {
  font-size: 14px;
  color: var(--text-secondary, #6B7280);
  margin-bottom: 32px;
}

.card {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 4px 20px rgba(236, 72, 153, 0.1);
}

.order-card {
  margin-bottom: 16px;
}

.order-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text, #1F2937);
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border, #E5E7EB);
}

.order-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
}

.label {
  color: var(--text-secondary, #6B7280);
  font-size: 14px;
}

.value {
  color: var(--text, #1F2937);
  font-size: 14px;
}

.tips {
  margin-bottom: 32px;
}

.tip-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text, #1F2937);
  margin-bottom: 12px;
}

.tip-item {
  font-size: 13px;
  color: var(--text-secondary, #6B7280);
  line-height: 1.8;
}

.btn-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.btn-primary {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  color: #fff;
  border: none;
  height: 48px;
  line-height: 48px;
  border-radius: 24px;
  font-size: 16px;
}

.btn-secondary {
  background: #fff;
  color: var(--primary, #EC4899);
  border: 1px solid var(--primary, #EC4899);
  height: 48px;
  line-height: 48px;
  border-radius: 24px;
  font-size: 16px;
}
