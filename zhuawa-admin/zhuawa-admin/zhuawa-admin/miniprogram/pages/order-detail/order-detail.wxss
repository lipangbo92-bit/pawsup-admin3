/* pages/order-detail/order-detail.wxss */
page {
  background: #FDF2F8;
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.header {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back, .title, .placeholder {
  color: #fff;
  font-size: 34rpx;
}

.back {
  font-size: 40rpx;
}

/* Status Card */
.status-card {
  margin: 32rpx;
  padding: 48rpx;
  border-radius: 24rpx;
  text-align: center;
}

.status-card.pending {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.status-card.paid {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.status-card.completed {
  background: linear-gradient(135deg, #E5E7EB 0%, #D1D5DB 100%);
}

.status-card.canceled {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
}

.status-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* Card */
.card {
  background: #fff;
  margin: 0 32rpx 32rpx;
  border-radius: 24rpx;
  padding: 32rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-row .label {
  color: #6B7280;
  font-size: 28rpx;
}

.info-row .value {
  color: #1F2937;
  font-size: 28rpx;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.contact-btn, .cancel-btn, .pay-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.contact-btn {
  background: #fff;
  color: #6B7280;
  border: 1rpx solid #D1D5DB;
}

.cancel-btn {
  background: #fff;
  color: #EC4899;
  border: 1rpx solid #EC4899;
}

.pay-btn {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  color: #fff;
}
