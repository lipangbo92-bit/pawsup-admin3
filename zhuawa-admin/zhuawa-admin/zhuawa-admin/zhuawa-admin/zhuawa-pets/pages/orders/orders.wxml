<!--pages/orders/orders.wxml-->
<view class="page-container">
  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-bg"></view>
    <view class="nav-content">
      <view class="nav-placeholder"></view>
      <text class="nav-title">我的订单</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 标签切换栏 -->
  <view class="tab-bar">
    <view 
      wx:for="{{tabs}}" 
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <!-- 订单卡片 -->
    <view 
      wx:for="{{filteredOrders}}" 
      wx:key="id"
      class="order-card"
      data-id="{{item.id}}"
      bindtap="onOrderClick"
    >
      <!-- 订单头部：编号 + 状态 -->
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <view class="status-tag status-{{item.status}}">
          {{item.status === 'pending' ? '待消费' : (item.status === 'completed' ? '已完成' : '已取消')}}
        </view>
      </view>

      <!-- 订单内容 -->
      <view class="order-body">
        <view class="service-icon">{{item.service.icon}}</view>
        <view class="order-info">
          <text class="service-name">{{item.service.name}}</text>
          <view class="meta-info">
            <text class="meta-item">{{item.technician}}</text>
            <text class="meta-dot">·</text>
            <text class="meta-item">{{item.date}} {{item.time}}</text>
            <text class="meta-dot">·</text>
            <text class="meta-item">{{item.pet}}</text>
          </view>
        </view>
      </view>

      <!-- 订单底部：价格 -->
      <view class="order-footer">
        <text class="price-label">实付金额：</text>
        <text class="price-value">¥{{item.service.price}}</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{filteredOrders.length === 0}}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无订单</text>
    </view>
  </view>
</view>
