.container {
  min-height: 100vh;
  background: var(--bg, #FDF2F8);
  padding: 16px;
}

.form {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 4px 20px rgba(236, 72, 153, 0.1);
}

.form-item {
  margin-bottom: 20px;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 14px;
  color: var(--text, #1F2937);
  display: block;
  margin-bottom: 8px;
}

.input {
  width: 100%;
  padding: 12px;
  border: 1px solid var(--border, #E5E7EB);
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

.type-list {
  display: flex;
  gap: 12px;
}

.type-item {
  padding: 10px 24px;
  border-radius: 20px;
  background: var(--bg, #FDF2F8);
  font-size: 14px;
  color: var(--text-secondary, #6B7280);
}

.type-item.active {
  background: var(--primary, #EC4899);
  color: #fff;
}

.save-btn {
  margin-top: 24px;
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  color: #fff;
  border: none;
  height: 48px;
  line-height: 48px;
  border-radius: 24px;
  font-size: 16px;
}
