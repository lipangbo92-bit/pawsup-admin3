<!--订单详情页-->
<view class="container" wx:if="{{order}}">
  <!--状态卡片-->
  <view class="status-card">
    <view class="status-icon {{order.status}}">
      <text wx:if="{{order.status === 'pending'}}">!</text>
      <text wx:elif="{{order.status === 'paid'}}">✓</text>
      <text wx:elif="{{order.status === 'completed'}}">✓</text>
      <text wx:elif="{{order.status === 'canceled'}}">×</text>
    </view>
    <view class="status-text">{{getStatusText(order.status)}}</view>
  </view>

  <!--订单信息-->
  <view class="section card">
    <view class="section-title">订单信息</view>
    <view class="info-row">
      <text class="label">订单编号</text>
      <text class="value">{{order.orderNo || order._id}}</text>
    </view>
    <view class="info-row">
      <text class="label">下单时间</text>
      <text class="value">{{order.createdAt}}</text>
    </view>
  </view>

  <!--服务信息-->
  <view class="section card">
    <view class="section-title">服务信息</view>
    <view class="info-row">
      <text class="label">服务项目</text>
      <text class="value">{{order.serviceName}}</text>
    </view>
    <view class="info-row">
      <text class="label">服务价格</text>
      <text class="value price">¥{{order.servicePrice}}</text>
    </view>
  </view>

  <!--预约信息-->
  <view class="section card">
    <view class="section-title">预约信息</view>
    <view class="info-row">
      <text class="label">宠物名字</text>
      <text class="value">{{order.petName}}</text>
    </view>
    <view class="info-row">
      <text class="label">预约日期</text>
      <text class="value">{{order.date}}</text>
    </view>
    <view class="info-row">
      <text class="label">预约时间</text>
      <text class="value">{{order.time}}</text>
    </view>
    <view class="info-row" wx:if="{{order.technicianName}}">
      <text class="label">技师</text>
      <text class="value">{{order.technicianName}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="label">备注</text>
      <text class="value">{{order.remark}}</text>
    </view>
  </view>

  <!--底部按钮-->
  <view class="footer" wx:if="{{order.status === 'pending'}}">
    <button class="btn-cancel" bindtap="cancelOrder">取消订单</button>
    <button class="btn-pay" bindtap="payOrder">立即支付</button>
  </view>
  
  <view class="footer" wx:if="{{order.status === 'paid'}}">
    <button class="btn-cancel" bindtap="cancelOrder">取消预约</button>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">加载中...</view>
