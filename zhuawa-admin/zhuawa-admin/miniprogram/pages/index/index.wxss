/* pages/index/index.wxss */
page {
  background: #FDF2F8;
}

.container {
  padding-bottom: 100rpx;
}

/* Header */
.header {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  padding: 32rpx 32rpx 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #fff;
  font-size: 26rpx;
  opacity: 0.9;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #7C3AED 0%, #EC4899 100%);
  margin: 32rpx;
  border-radius: 32rpx;
  padding: 40rpx;
}

.banner-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.banner-desc {
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.banner-btn {
  background: #fff;
  color: #EC4899;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: inline-block;
}

/* Grid Menu */
.grid-menu {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  padding: 0 32rpx;
}

.grid-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 40rpx rgba(236, 72, 153, 0.1);
}

.grid-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.grid-label {
  font-size: 24rpx;
  color: #1F2937;
  font-weight: 500;
}

.grid-tag {
  background: #EC4899;
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-top: 8rpx;
  display: inline-block;
}

/* Section */
.section {
  margin-top: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1F2937;
}

.section-more {
  font-size: 26rpx;
  color: #DB2777;
}

/* Tech Scroll */
.tech-scroll {
  white-space: nowrap;
  padding: 0 32rpx;
}

.tech-card {
  display: inline-block;
  width: 280rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  text-align: center;
  margin-right: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(236, 72, 153, 0.1);
  vertical-align: top;
}

.tech-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F9A8D4 0%, #EC4899 100%);
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.tech-name {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.tech-level {
  background: #FCE7F3;
  color: #DB2777;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 16rpx;
}

.tech-rating {
  font-size: 24rpx;
  color: #F59E0B;
  margin-bottom: 16rpx;
}

.tech-btn {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  color: #fff;
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* Service List */
.service-list {
  padding: 0 32rpx;
}

.service-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(236, 72, 153, 0.1);
}

.service-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FBCFE8 0%, #F9A8D4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.service-name {
  font-weight: 600;
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.service-meta {
  font-size: 24rpx;
  color: #BE185D;
  margin-bottom: 16rpx;
}

.service-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #EC4899;
}

.service-price text {
  font-size: 24rpx;
  font-weight: 400;
}
