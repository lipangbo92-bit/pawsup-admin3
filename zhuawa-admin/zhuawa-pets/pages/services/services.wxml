<!--pages/services/services.wxml-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-bg" style="position: absolute; left: 6rpx; top: -20rpx"></view>
    <view class="nav-content" style="width: 750rpx; display: flex; box-sizing: content-box; left: 0rpx; top: 0rpx; height: -125rpx">
      <view class="nav-placeholder"></view>
      <text class="nav-title">服务项目</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 左右分栏布局 -->
  <view class="main-content">
    <!-- 左侧分类导航 -->
    <scroll-view class="category-nav" scroll-top="{{categoryScrollTop}}" scroll-y enhanced show-scrollbar="{{false}}">
      <view 
        wx:for="{{categories}}" 
        wx:key="index"
        class="category-item {{currentCategory === index ? 'active' : ''}}"
        bindtap="switchCategory"
        data-index="{{index}}"
      >
        <text class="category-text">{{item}}</text>
      </view>
    </scroll-view>

    <!-- 右侧服务列表 -->
    <scroll-view class="service-list" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="service-content">
        <view 
          wx:for="{{services[currentCategory]}}" 
          wx:key="id"
          class="service-card" style="width: 500rpx; display: flex; box-sizing: border-box"
        >
          <view class="service-icon-wrapper {{item.iconClass}}">
            <text class="icon-text">{{item.iconText}}</text>
          </view>
          <view class="service-info">
            <view>
              <text class="service-name">{{item.name}}</text>
              <text class="service-desc">{{item.desc}}</text>
            </view>
            <view class="service-bottom">
              <view class="price-wrapper">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.price}}</text>
                <text class="price-unit">{{item.unit}}</text>
              </view>
              <view class="book-btn" bindtap="bookService" data-service="{{item.id}}">
                <text class="book-icon">+</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
