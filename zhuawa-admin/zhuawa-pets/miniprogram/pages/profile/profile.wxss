.container {
  min-height: 100vh;
  background: var(--bg, #FDF2F8);
}

.header {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  padding: 40px 16px 60px;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  border: 3px solid rgba(255,255,255,0.3);
}

.avatar.placeholder {
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: #fff;
}

.nickname {
  margin-left: 16px;
  font-size: 20px;
  font-weight: 600;
  color: #fff;
}

.login-btn {
  margin-left: 16px;
  background: rgba(255,255,255,0.2);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.5);
  font-size: 14px;
  padding: 8px 24px;
  border-radius: 20px;
}

.stats-card {
  background: #fff;
  margin: -40px 16px 16px;
  border-radius: 16px;
  padding: 20px;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4px 20px rgba(236, 72, 153, 0.1);
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: var(--primary, #EC4899);
}

.stat-label {
  font-size: 12px;
  color: var(--text-secondary, #6B7280);
  margin-top: 4px;
}

.menu-list {
  margin: 16px;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(236, 72, 153, 0.1);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid var(--border, #E5E7EB);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 20px;
  margin-right: 12px;
}

.menu-title {
  font-size: 15px;
  color: var(--text, #1F2937);
}

.menu-arrow {
  font-size: 20px;
  color: var(--text-secondary, #6B7280);
}
