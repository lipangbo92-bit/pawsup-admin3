/* pages/pet-edit/pet-edit.wxss */
page {
  background: #FDF2F8;
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.avatar-upload {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(236, 72, 153, 0.2);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FBCFE8 0%, #F9A8D4 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.avatar-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.avatar-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-icon {
  font-size: 32rpx;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 16rpx;
}

.label.required::after {
  content: '*';
  color: #EF4444;
  margin-left: 8rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1F2937;
  box-sizing: border-box;
}

.input::placeholder {
  color: #9CA3AF;
}

/* 类型选择器 */
.type-selector {
  display: flex;
  gap: 24rpx;
}

.type-option {
  flex: 1;
  height: 120rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx solid transparent;
}

.type-option.active {
  background: #FDF2F8;
  border-color: #EC4899;
}

.type-icon {
  font-size: 48rpx;
}

.type-text {
  font-size: 24rpx;
  color: #6B7280;
}

.type-option.active .type-text {
  color: #EC4899;
  font-weight: 500;
}

/* 年龄选择器 */
.age-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.age-input {
  width: 200rpx;
}

.age-unit {
  font-size: 28rpx;
  color: #6B7280;
}

/* 体重选择器 */
.weight-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weight-input {
  width: 200rpx;
}

.weight-unit {
  font-size: 28rpx;
  color: #6B7280;
}

/* 性别选择器 */
.gender-selector {
  display: flex;
  gap: 24rpx;
}

.gender-option {
  flex: 1;
  height: 88rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 2rpx solid transparent;
}

.gender-option.active {
  background: #FDF2F8;
  border-color: #EC4899;
}

.gender-icon {
  font-size: 32rpx;
}

.gender-text {
  font-size: 28rpx;
  color: #6B7280;
}

.gender-option.active .gender-text {
  color: #EC4899;
  font-weight: 500;
}

/* 文本域 */
.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1F2937;
  box-sizing: border-box;
}

.textarea::placeholder {
  color: #9CA3AF;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.delete-btn {
  width: 240rpx;
  height: 88rpx;
  background: #FEE2E2;
  color: #EF4444;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.delete-btn:active {
  opacity: 0.8;
}

.save-btn {
  flex: 1;
  height: 88rpx;
  background: #D1D5DB;
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.save-btn.active {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  box-shadow: 0 8rpx 24rpx rgba(236, 72, 153, 0.3);
}

.save-btn:active {
  opacity: 0.9;
}