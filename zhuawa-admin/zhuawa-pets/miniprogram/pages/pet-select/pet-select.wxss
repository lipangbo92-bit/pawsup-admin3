.container {
  min-height: 100vh;
  background: var(--bg, #FDF2F8);
  padding: 16px;
  padding-bottom: 100px;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text, #1F2937);
  margin-bottom: 16px;
  text-align: center;
}

.pet-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.pet-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 4px 20px rgba(236, 72, 153, 0.1);
}

.pet-card.selected {
  border: 2px solid var(--primary, #EC4899);
  background: #FCE7F3;
}

.pet-avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: var(--bg, #FDF2F8);
}

.pet-info {
  flex: 1;
  margin-left: 12px;
}

.pet-name {
  font-size: 16px;
  font-weight: 600;
  color: var(--text, #1F2937);
  display: block;
}

.pet-breed {
  font-size: 13px;
  color: var(--text-secondary, #6B7280);
  margin-top: 4px;
  display: block;
}

.check-icon {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--primary, #EC4899);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.add-pet-card {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  border: 2px dashed var(--border, #E5E7EB);
}

.add-icon {
  font-size: 24px;
  color: var(--primary, #EC4899);
  margin-right: 8px;
}

.add-text {
  font-size: 15px;
  color: var(--primary, #EC4899);
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16px;
}

.confirm-btn {
  background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
  color: #fff;
  border: none;
  height: 48px;
  line-height: 48px;
  border-radius: 24px;
  font-size: 16px;
}

.confirm-btn[disabled] {
  background: #ccc;
}
