/* 遮罩层 */
.pet-selector-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

/* 弹窗 */
.pet-selector-popup {
  width: 100%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

/* 头部 */
.selector-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #F3F4F6;
  position: relative;
}

.selector-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.selector-close {
  position: absolute;
  right: 32rpx;
  font-size: 48rpx;
  color: #9CA3AF;
  line-height: 1;
}

/* 宠物列表 */
.pet-list {
  flex: 1;
  padding: 24rpx;
  max-height: 50vh;
}

.pet-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.pet-card.selected {
  background: #FFF7ED;
  border-color: #F97316;
}

.pet-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #E5E7EB;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pet-avatar image {
  width: 100%;
  height: 100%;
}

.pet-emoji {
  font-size: 48rpx;
}

.pet-info {
  flex: 1;
  margin-left: 24rpx;
}

.pet-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
}

.pet-meta {
  font-size: 26rpx;
  color: #6B7280;
  margin-top: 8rpx;
  display: block;
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F97316;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 添加宠物卡片 */
.add-pet-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: #FFFFFF;
  border: 4rpx dashed #E5E7EB;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.add-icon {
  font-size: 40rpx;
  color: #F97316;
  margin-right: 16rpx;
}

.add-text {
  font-size: 30rpx;
  color: #F97316;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 48rpx;
}

.add-btn {
  width: 320rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.add-btn::after {
  border: none;
}

/* 底部 */
.selector-footer {
  padding: 24rpx 48rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #F3F4F6;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  color: #FFFFFF;
}

.confirm-btn.disabled {
  background: #E5E7EB;
  color: #9CA3AF;
}

.confirm-btn.active {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
}

.confirm-btn::after {
  border: none;
}

/* 加载中 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  font-size: 28rpx;
  color: #6B7280;
}
